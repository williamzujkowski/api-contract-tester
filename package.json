{
  "name": "api-contract-tester",
  "version": "1.0.0",
  "description": "Generate and run contract tests from OpenAPI 3.0 specs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "api-contract-tester": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
